{
  "name": "humble_dev-x86",
   "build": {
    "dockerfile": "Dockerfile.humble",
    "context": "../.."
  },


  "initializeCommand": "xhost + || true",

  "runArgs": [
    "--gpus", "all",
    "--net=host",
    "--ipc=host",
	  "--volume", "/tmp/.X11-unix:/tmp/.X11-unix:rw",
	  "--volume", "/dev:/dev",
    "--device=/dev/bus/usb:/dev/bus/usb", //include zed 2 device
    "--device=/dev/ttyACM0:/dev/ttyACM0", //include ACM0 serial device
    "--device-cgroup-rule", "c 240:* rmw",
    "--device-cgroup-rule", "c 81:* rmw",
    "--device-cgroup-rule", "c 31:* rmw",
    "--device=/dev/input",
    "--env", "NVIDIA_VISIBLE_DEVICES=all",
    "--env", "NVIDIA_DRIVER_CAPABILITIES=all",
    "--env", "QT_X11_NO_MITSHM=1",
    "--env", "__GLX_VENDOR_LIBRARY_NAME=nvidia",
    "--env", "__NV_PRIME_RENDER_OFFLOAD=1",
    "--env", "__VK_LAYER_NV_optimus=NVIDIA_only",
    "--group-add=input"
  ],

  "workspaceMount": "source=${localWorkspaceFolder}/ros2_src,target=/home/ros_user/ros2_ws/src,type=bind,consistency=cached",
  "workspaceFolder": "/home/ros_user/ros2_ws",

  "containerEnv": {
    "ROS_DISTRO": "humble",
    "RMW_IMPLEMENTATION": "rmw_cyclonedds_cpp",
    "DISPLAY": "${localEnv:DISPLAY}",
		"WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}", 
		"XDG_RUNTIME_DIR": "${localEnv:XDG_RUNTIME_DIR}"
  },

  //"postStartCommand": "bash -c 'source /opt/ros/${ROS_DISTRO}/setup.bash && colcon build --packages-skip-regex ^zed --symlink-install --parallel-workers $(nproc)'",
  "postCreateCommand": "bash -lc \"sudo chmod -R 755 /usr/local/lib/python3.10/dist-packages/ && grep -qxF 'source /opt/ros/humble/setup.bash' /home/ros_user/.bashrc || echo 'source /opt/ros/humble/setup.bash' >> /home/ros_user/.bashrc; grep -qxF 'if [ -f ~/ros2_ws/install/setup.bash ]; then source ~/ros2_ws/install/setup.bash; fi' /home/ros_user/.bashrc || echo 'if [ -f ~/ros2_ws/install/setup.bash ]; then source ~/ros2_ws/install/setup.bash; fi' >> /home/ros_user/.bashrc\"",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-python.python",
        "twxs.cmake",
        "ms-vscode.cpptools",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "files.eol": "\n",
        "editor.wordWrap": "on"
      }
    }
  },

  "remoteUser": "ros_user"
}
